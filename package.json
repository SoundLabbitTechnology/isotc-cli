{
  "name": "isotc-cli",
  "version": "0.5.0",
  "description": "Intent-to-Spec Optimal Transport Compiler CLI - 仕様・アーキテクチャ境界の検証とトレーサビリティ支援",
  "main": "dist/index.js",
  "bin": {
    "isotc": "bin/isotc.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "start": "node bin/isotc.js",
    "verify": "node bin/isotc.js verify",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "architecture",
    "ai",
    "verification",
    "intent"
  ],
  "author": "Sound Labbit Technology Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoundLabbitTechnology/isotc-cli.git"
  },
  "bugs": {
    "url": "https://github.com/SoundLabbitTechnology/isotc-cli/issues"
  },
  "homepage": "https://github.com/SoundLabbitTechnology/isotc-cli#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.45.0",
    "@iarna/toml": "^2.2.5",
    "commander": "^12.0.0",
    "minimatch": "^9.0.9",
    "openai": "^6.27.0",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "bin",
    "dist",
    "schemas",
    "resources",
    "LICENSE",
    "NOTICE"
  ]
}
